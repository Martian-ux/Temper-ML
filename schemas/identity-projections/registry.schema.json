{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "registry.schema.json",
  "type": "object",
  "required": ["schema_version", "registrations"],
  "properties": {
    "schema_version": {"const": "v1"},
    "registrations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["record_type", "record_schema_version", "projection_name", "projection_version", "record_schema"],
        "properties": {
          "record_type": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "record_schema_version": {"type": "string", "pattern": "^v[1-9][0-9]*$"},
          "projection_name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*$"},
          "projection_version": {"type": "string", "pattern": "^v[1-9][0-9]*$"},
          "record_schema": {"type": "string", "pattern": "^schemas/records/[a-z_]+\\.schema\\.json$"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
