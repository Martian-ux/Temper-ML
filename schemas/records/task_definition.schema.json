{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task_definition.schema.json",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/envelope"},
    {
      "properties": {
        "record_type": {"const": "task_definition"},
        "payload": {
          "type": "object",
          "required": ["task_id", "display_name", "description", "input_schema", "output_schema", "rendering_contract", "objectives", "capabilities"],
          "properties": {
            "task_id": {"$ref": "common.schema.json#/$defs/identifier"},
            "display_name": {"$ref": "common.schema.json#/$defs/nonEmptyText"},
            "description": {"$ref": "common.schema.json#/$defs/nonEmptyText"},
            "input_schema": {"type": "object"},
            "output_schema": {"type": "object"},
            "rendering_contract": {"$ref": "common.schema.json#/$defs/identity"},
            "objectives": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "common.schema.json#/$defs/nonEmptyText"}},
            "capabilities": {"type": "array", "uniqueItems": true, "items": {"$ref": "common.schema.json#/$defs/nonEmptyText"}}
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
