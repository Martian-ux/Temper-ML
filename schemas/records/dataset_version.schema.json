{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dataset_version.schema.json",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/envelope"},
    {
      "properties": {
        "record_type": {"const": "dataset_version"},
        "payload": {
          "type": "object",
          "required": [
            "version_id",
            "source",
            "field_mapping",
            "renderer",
            "renderer_identity",
            "filter_rule",
            "deduplication_rule",
            "tokenizer_identity",
            "split_rule",
            "split_identity",
            "rendered_bytes_format",
            "rendered_bytes_identity",
            "rendered_bytes_count",
            "preview_limit",
            "preview_selections",
            "accepted_examples",
            "split_membership",
            "exclusions",
            "statistics"
          ],
          "properties": {
            "version_id": {"$ref": "common.schema.json#/$defs/identifier"},
            "source": {"$ref": "#/$defs/source"},
            "field_mapping": {"$ref": "#/$defs/fieldMapping"},
            "renderer": {"$ref": "#/$defs/renderer"},
            "renderer_identity": {"$ref": "common.schema.json#/$defs/identity"},
            "filter_rule": {"$ref": "#/$defs/filterRule"},
            "deduplication_rule": {"$ref": "#/$defs/deduplicationRule"},
            "tokenizer_identity": {"$ref": "common.schema.json#/$defs/identity"},
            "split_rule": {"$ref": "#/$defs/splitRule"},
            "split_identity": {"$ref": "common.schema.json#/$defs/identity"},
            "rendered_bytes_format": {"const": "temper.dataset.rendered-jsonl@v1"},
            "rendered_bytes_identity": {"$ref": "common.schema.json#/$defs/identity"},
            "rendered_bytes_count": {"type": "integer", "minimum": 1},
            "preview_limit": {"type": "integer", "minimum": 0},
            "preview_selections": {
              "type": "array",
              "items": {"$ref": "#/$defs/previewSelection"}
            },
            "accepted_examples": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/acceptedExample"}
            },
            "split_membership": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/splitMembership"}
            },
            "exclusions": {
              "type": "array",
              "items": {"$ref": "#/$defs/exclusionReceipt"}
            },
            "statistics": {"$ref": "#/$defs/statistics"}
          },
          "additionalProperties": false
        }
      }
    }
  ],
  "$defs": {
    "source": {
      "type": "object",
      "required": ["adapter", "source_identity", "row_count"],
      "properties": {
        "adapter": {
          "enum": ["json@v1", "jsonl@v1", "csv@v1", "hugging_face_rows@v1"]
        },
        "source_identity": {"$ref": "common.schema.json#/$defs/identity"},
        "row_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "fieldMapping": {
      "type": "object",
      "required": ["instruction_field", "response_field", "context_field"],
      "properties": {
        "instruction_field": {"$ref": "common.schema.json#/$defs/identifier"},
        "response_field": {"$ref": "common.schema.json#/$defs/identifier"},
        "context_field": {
          "oneOf": [
            {"$ref": "common.schema.json#/$defs/identifier"},
            {"type": "null"}
          ]
        }
      },
      "additionalProperties": false
    },
    "renderer": {
      "type": "object",
      "required": ["kind", "version"],
      "properties": {
        "kind": {"const": "instruction_response"},
        "version": {"const": "v1"}
      },
      "additionalProperties": false
    },
    "filterRule": {
      "type": "object",
      "required": ["minimum_characters", "maximum_characters", "maximum_tokens"],
      "properties": {
        "minimum_characters": {"type": "integer", "minimum": 0},
        "maximum_characters": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "maximum_tokens": {"type": ["integer", "null"], "minimum": 1}
      },
      "additionalProperties": false
    },
    "deduplicationRule": {
      "type": "object",
      "required": ["mode", "keep"],
      "properties": {
        "mode": {"const": "exact_rendered_text"},
        "keep": {"const": "first_source_order"}
      },
      "additionalProperties": false
    },
    "splitPart": {
      "type": "object",
      "required": ["name", "weight"],
      "properties": {
        "name": {"$ref": "common.schema.json#/$defs/identifier"},
        "weight": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "splitRule": {
      "type": "object",
      "required": ["algorithm", "seed", "parts"],
      "properties": {
        "algorithm": {"const": "sha256_weighted_bucket@v1"},
        "seed": {"type": "integer", "minimum": 0},
        "parts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/splitPart"}
        }
      },
      "additionalProperties": false
    },
    "acceptedExample": {
      "type": "object",
      "required": ["source_ordinal", "rendered_identity", "rendered_utf8_bytes", "token_count"],
      "properties": {
        "source_ordinal": {"type": "integer", "minimum": 1},
        "rendered_identity": {"$ref": "common.schema.json#/$defs/identity"},
        "rendered_utf8_bytes": {"type": "integer", "minimum": 1},
        "token_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "previewSelection": {
      "type": "object",
      "required": ["source_ordinal", "rendered_identity", "split", "token_count"],
      "properties": {
        "source_ordinal": {"type": "integer", "minimum": 1},
        "rendered_identity": {"$ref": "common.schema.json#/$defs/identity"},
        "split": {"$ref": "common.schema.json#/$defs/identifier"},
        "token_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "splitMembership": {
      "type": "object",
      "required": ["rendered_identity", "split"],
      "properties": {
        "rendered_identity": {"$ref": "common.schema.json#/$defs/identity"},
        "split": {"$ref": "common.schema.json#/$defs/identifier"}
      },
      "additionalProperties": false
    },
    "exclusionReceipt": {
      "type": "object",
      "required": ["source_ordinal", "phase", "reason_code", "retained_source_ordinal"],
      "properties": {
        "source_ordinal": {"type": "integer", "minimum": 1},
        "phase": {"enum": ["validation", "filtering", "deduplication"]},
        "reason_code": {"$ref": "common.schema.json#/$defs/identifier"},
        "retained_source_ordinal": {"type": ["integer", "null"], "minimum": 1}
      },
      "additionalProperties": false
    },
    "splitCount": {
      "type": "object",
      "required": ["split", "count"],
      "properties": {
        "split": {"$ref": "common.schema.json#/$defs/identifier"},
        "count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "statistics": {
      "type": "object",
      "required": [
        "source_rows",
        "accepted_rows",
        "excluded_rows",
        "duplicate_rows",
        "total_tokens",
        "minimum_tokens",
        "maximum_tokens",
        "split_counts"
      ],
      "properties": {
        "source_rows": {"type": "integer", "minimum": 0},
        "accepted_rows": {"type": "integer", "minimum": 1},
        "excluded_rows": {"type": "integer", "minimum": 0},
        "duplicate_rows": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "minimum_tokens": {"type": "integer", "minimum": 0},
        "maximum_tokens": {"type": "integer", "minimum": 0},
        "split_counts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/splitCount"}
        }
      },
      "additionalProperties": false
    }
  }
}
