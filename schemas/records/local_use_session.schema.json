{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local_use_session.schema.json",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/envelope"},
    {
      "properties": {
        "record_type": {"const": "local_use_session"},
        "payload": {
          "type": "object",
          "required": ["session_id", "project", "artifact", "artifact_content_identity", "base_model_revision", "tokenizer_identity", "compatibility_group", "execution_target", "inference_settings", "inputs", "outputs", "runtime_evidence", "integrity_evidence", "evaluation_captures"],
          "properties": {
            "session_id": {"$ref": "common.schema.json#/$defs/identifier"},
            "project": {"$ref": "common.schema.json#/$defs/projectReference"},
            "artifact": {"$ref": "common.schema.json#/$defs/artifactReference"},
            "artifact_content_identity": {"$ref": "common.schema.json#/$defs/identity"},
            "base_model_revision": {"$ref": "common.schema.json#/$defs/baseModelRevisionReference"},
            "tokenizer_identity": {"$ref": "common.schema.json#/$defs/identity"},
            "compatibility_group": {"$ref": "common.schema.json#/$defs/compatibilityGroupReference"},
            "execution_target": {"$ref": "common.schema.json#/$defs/executionTargetReference"},
            "inference_settings": {"type": "object"},
            "inputs": {"type": "array", "minItems": 1, "items": {"type": "object"}},
            "outputs": {"type": "array", "minItems": 1, "items": {"type": "object"}},
            "runtime_evidence": {"$ref": "common.schema.json#/$defs/identity"},
            "integrity_evidence": {"$ref": "common.schema.json#/$defs/identity"},
            "evaluation_captures": {"type": "array", "uniqueItems": true, "items": {"$ref": "common.schema.json#/$defs/identity"}}
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
