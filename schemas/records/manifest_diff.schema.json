{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manifest_diff.schema.json",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/envelope"},
    {
      "properties": {
        "record_type": {"const": "manifest_diff"},
        "payload": {
          "type": "object",
          "required": ["diff_id", "parent_manifest_identity", "derived_manifest_identity", "changes"],
          "properties": {
            "diff_id": {"$ref": "common.schema.json#/$defs/identifier"},
            "parent_manifest_identity": {"$ref": "common.schema.json#/$defs/identity"},
            "derived_manifest_identity": {"$ref": "common.schema.json#/$defs/identity"},
            "changes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": ["path", "operation", "after"],
                    "properties": {
                      "path": {"type": "string", "pattern": "^/.*$"},
                      "operation": {"const": "add"},
                      "after": {}
                    },
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "required": ["path", "operation", "before"],
                    "properties": {
                      "path": {"type": "string", "pattern": "^/.*$"},
                      "operation": {"const": "remove"},
                      "before": {}
                    },
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "required": ["path", "operation", "before", "after"],
                    "properties": {
                      "path": {"type": "string", "pattern": "^(?:$|/.*)$"},
                      "operation": {"const": "replace"},
                      "before": {},
                      "after": {}
                    },
                    "additionalProperties": false
                  }
                ]
              }
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
