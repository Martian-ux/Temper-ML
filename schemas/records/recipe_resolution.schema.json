{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recipe_resolution.schema.json",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/envelope"},
    {
      "properties": {
        "record_type": {"const": "recipe_resolution"},
        "payload": {
          "type": "object",
          "required": ["resolution_id", "recipe", "base_model_revision", "hardware_requirements", "execution_target", "adapter_type", "target_modules", "rank", "alpha", "dropout", "learning_rate", "effective_batch_size", "sequence_length", "optimizer", "precision", "gradient_accumulation", "seed", "schedule", "training_steps", "checkpoint_cadence", "quantization", "library_versions", "applied_constraints"],
          "properties": {
            "resolution_id": {"$ref": "common.schema.json#/$defs/identifier"},
            "recipe": {"$ref": "common.schema.json#/$defs/recipeReference"},
            "base_model_revision": {"$ref": "common.schema.json#/$defs/baseModelRevisionReference"},
            "hardware_requirements": {"$ref": "common.schema.json#/$defs/hardwareRequirementsReference"},
            "execution_target": {"$ref": "common.schema.json#/$defs/executionTargetReference"},
            "adapter_type": {"$ref": "common.schema.json#/$defs/identifier"},
            "target_modules": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "common.schema.json#/$defs/nonEmptyText"}},
            "rank": {"type": "integer", "minimum": 1},
            "alpha": {"type": "integer", "minimum": 1},
            "dropout": {"type": "number", "minimum": 0, "exclusiveMaximum": 1},
            "learning_rate": {"type": "number", "exclusiveMinimum": 0},
            "effective_batch_size": {"type": "integer", "minimum": 1},
            "sequence_length": {"type": "integer", "minimum": 1},
            "optimizer": {"$ref": "common.schema.json#/$defs/identifier"},
            "precision": {"$ref": "common.schema.json#/$defs/identifier"},
            "gradient_accumulation": {"type": "integer", "minimum": 1},
            "seed": {"type": "integer", "minimum": 0},
            "schedule": {"$ref": "common.schema.json#/$defs/identifier"},
            "training_steps": {"type": "integer", "minimum": 1},
            "checkpoint_cadence": {"type": "integer", "minimum": 1},
            "quantization": {"$ref": "common.schema.json#/$defs/identifier"},
            "library_versions": {"type": "object"},
            "applied_constraints": {"type": "array", "uniqueItems": true, "items": {"$ref": "common.schema.json#/$defs/nonEmptyText"}}
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
