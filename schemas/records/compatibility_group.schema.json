{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "compatibility_group.schema.json",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/envelope"},
    {
      "properties": {
        "record_type": {"const": "compatibility_group"},
        "payload": {
          "type": "object",
          "required": ["group_id", "base_model_revision", "tokenizer_identity", "rendering_template", "adapter_type", "target_modules", "runtime_targets", "merge_methods"],
          "properties": {
            "group_id": {"$ref": "common.schema.json#/$defs/identifier"},
            "base_model_revision": {"$ref": "common.schema.json#/$defs/baseModelRevisionReference"},
            "tokenizer_identity": {"$ref": "common.schema.json#/$defs/identity"},
            "rendering_template": {"$ref": "common.schema.json#/$defs/identity"},
            "adapter_type": {"$ref": "common.schema.json#/$defs/identifier"},
            "target_modules": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "common.schema.json#/$defs/nonEmptyText"}},
            "runtime_targets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["target_class", "accelerator_backend", "runtime_contract", "required_capabilities"],
                "properties": {
                  "target_class": {"$ref": "common.schema.json#/$defs/identifier"},
                  "accelerator_backend": {"$ref": "common.schema.json#/$defs/identifier"},
                  "runtime_contract": {"$ref": "common.schema.json#/$defs/identity"},
                  "required_capabilities": {"type": "array", "uniqueItems": true, "items": {"$ref": "common.schema.json#/$defs/nonEmptyText"}}
                },
                "additionalProperties": false
              }
            },
            "merge_methods": {"type": "array", "uniqueItems": true, "items": {"$ref": "common.schema.json#/$defs/nonEmptyText"}}
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
